{
  "name": "giles-memory-machine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ulimit -n 10240 2>/dev/null || true; next dev --hostname 127.0.0.1",
    "dev:remote": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "lint": "next lint",
    "print-paths": "node scripts/print-paths.mjs"
  },
