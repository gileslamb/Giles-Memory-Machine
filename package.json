    "@anthropic-ai/sdk": "^0.32.1",
    "@hello-pangea/dnd": "^18.0.1",
    "chokidar": "^5.0.0",
    "mammoth": "^1.11.0",
    "next": "^15.1.0",
    "ollama": "^0.6.3",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2"
  }
